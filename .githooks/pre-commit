#!/usr/bin/env bash
# Pre-commit hook:
#   1. Strips outputs from any staged .ipynb files and re-stages them
#   2. Freezes current pip environment into requirements.txt and re-stages it

set -e

# Resolve python/nbstripout from .venv if available, otherwise fall back to PATH
REPO_ROOT=$(git rev-parse --show-toplevel)
if [ -f "$REPO_ROOT/.venv/bin/python" ]; then
    PYTHON="$REPO_ROOT/.venv/bin/python"
    PIP="$REPO_ROOT/.venv/bin/pip"
    NBSTRIPOUT="$REPO_ROOT/.venv/bin/nbstripout"
else
    PYTHON=$(command -v python3 || command -v python)
    PIP=$(command -v pip3 || command -v pip)
    NBSTRIPOUT=$(command -v nbstripout || echo "")
fi

# --- 1. Strip notebook outputs ---
NOTEBOOKS=$(git diff --cached --name-only --diff-filter=ACM | grep '\.ipynb$' || true)

if [ -n "$NOTEBOOKS" ]; then
    if [ -z "$NBSTRIPOUT" ] || [ ! -x "$NBSTRIPOUT" ]; then
        echo "ERROR: nbstripout not found. Run: bash setup.sh"
        exit 1
    fi
    for nb in $NOTEBOOKS; do
        echo "[pre-commit] Stripping outputs from $nb"
        "$NBSTRIPOUT" "$REPO_ROOT/$nb"
        git add "$REPO_ROOT/$nb"
    done
fi

# --- 2. Freeze pip environment into requirements.txt ---
if [ -n "$PIP" ] && [ -x "$PIP" ]; then
    echo "[pre-commit] Updating requirements.txt"
    "$PIP" freeze > "$REPO_ROOT/requirements.txt"
    git add "$REPO_ROOT/requirements.txt"
fi
